    "mcp",
    "model-context-protocol",
    "x402",
    "agentic",
    "ai-agent",
    "ai-agents",
    "llm",
    "hive",
    "hive-civilization",
    "trade-finance",
    "cross-border",
    "smb",
    "usdt",
    "usdc",
    "base",
    "base-l2",
    "ethereum",
    "solana",
    "invoice",
    "supply-chain",
    "a2a",
    "agent-card",
    "oac",
    "open-agent-card",
    "attribution",
    "earn"
  ],
  "author": "Steve Rotzin <steve@thehiveryiq.com> (https://www.thehiveryiq.com)",
  "license": "MIT",
  "homepage": "https://github.com/srotzin/hive-mcp-trade",
  "repository": {
    "type": "git",
